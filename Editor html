<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editor Undangan Fikri & Sindi</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: #0a0a0c;
            font-family: 'Segoe UI', 'Montserrat', sans-serif;
            padding: 40px 20px;
            color: #f0ede8;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
        }
        h1 {
            text-align: center;
            color: #e5c890;
            margin-bottom: 30px;
            font-family: 'Playfair Display', serif;
        }
        .form-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #e5c890;
            font-size: 14px;
        }
        input, textarea {
            width: 100%;
            padding: 12px 16px;
            background: rgba(30, 30, 40, 0.8);
            border: 1px solid rgba(212, 175, 55, 0.4);
            border-radius: 16px;
            color: #f0ede8;
            font-family: inherit;
            font-size: 14px;
        }
        input:focus, textarea:focus {
            outline: none;
            border-color: #e5c890;
        }
        .row {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }
        .row > div {
            flex: 1;
            min-width: 200px;
        }
        .btn-generate {
            background: linear-gradient(135deg, #e5c890, #c8a15e);
            color: #0a0a0c;
            border: none;
            padding: 14px 28px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 40px;
            cursor: pointer;
            width: 100%;
            margin-top: 20px;
            transition: transform 0.2s;
        }
        .btn-generate:hover {
            transform: translateY(-2px);
        }
        .result {
            margin-top: 40px;
            border-top: 1px solid rgba(212, 175, 55, 0.3);
            padding-top: 30px;
        }
        .result h3 {
            color: #e5c890;
            margin-bottom: 15px;
        }
        textarea.result-code {
            background: #1a1a1f;
            font-family: monospace;
            font-size: 12px;
            height: 400px;
            resize: vertical;
        }
        .copy-btn {
            background: rgba(229, 200, 144, 0.2);
            border: 1px solid #e5c890;
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            margin-top: 10px;
            color: #e5c890;
            font-size: 12px;
        }
        .copy-btn:hover {
            background: #e5c890;
            color: #0a0a0c;
        }
        hr {
            border-color: rgba(212, 175, 55, 0.2);
            margin: 20px 0;
        }
        .note {
            font-size: 12px;
            color: #b8a87a;
            text-align: center;
            margin-top: 30px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>✨ Editor Undangan Pernikahan ✨</h1>
        <p style="text-align:center; margin-bottom:30px;">Isi data di bawah, klik generate, copy kode HTML ke file index.html</p>

        <form id="weddingForm">
            <!-- Nama Mempelai -->
            <div class="row">
                <div class="form-group">
                    <label>👨‍💼 Nama Pria</label>
                    <input type="text" id="namaPria" value="Fikri Anugrah R.">
                </div>
                <div class="form-group">
                    <label>👰‍♀️ Nama Wanita</label>
                    <input type="text" id="namaWanita" value="Sindi Rosmiati">
                </div>
            </div>

            <!-- Nama Orang Tua -->
            <div class="row">
                <div class="form-group">
                    <label>👨‍👩‍👦 Ayah & Ibu Pria</label>
                    <input type="text" id="ortuPria" value="Bapak Heri Nugraha & Ibu Nurhayati">
                </div>
                <div class="form-group">
                    <label>👨‍👩‍👧 Ayah & Ibu Wanita</label>
                    <input type="text" id="ortuWanita" value="Bapak Enjang Supriyadi & Ibu Elis Herawati">
                </div>
            </div>

            <!-- Tanggal -->
            <div class="row">
                <div class="form-group">
                    <label>📅 Tanggal Pernikahan</label>
                    <input type="text" id="tanggal" value="Minggu, 05 April 2026">
                </div>
                <div class="form-group">
                    <label>🕐 Waktu (opsional)</label>
                    <input type="text" id="waktu" value="08:00 WIB">
                </div>
            </div>

            <!-- Lokasi -->
            <div class="form-group">
                <label>📍 Lokasi Acara</label>
                <textarea id="lokasi" rows="2">Kp. Cianca RT 001/008, Desa Cisomang Barat
Cikalong Wetan, Bandung Barat</textarea>
            </div>

            <div class="form-group">
                <label>🗺️ Petunjuk Arah</label>
                <textarea id="petunjuk" rows="2">Dari Bandung ambil jalur Cikalong Wetan, setelah SPBU belok kanan ke Cisomang, ikuti jalan 2km, lokasi samping Masjid Al-Ikhlas.</textarea>
            </div>

            <hr>

            <!-- Rekening -->
            <div class="row">
                <div class="form-group">
                    <label>💳 BCA - Nomor Rekening</label>
                    <input type="text" id="bcaRek" value="1234 5678 9012 3456">
                </div>
                <div class="form-group">
                    <label>💳 BCA - a.n.</label>
                    <input type="text" id="bcaAn" value="Fikri Anugrah">
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label>🏦 Mandiri - Nomor Rekening</label>
                    <input type="text" id="mandiriRek" value="1234 5678 9012 3456">
                </div>
                <div class="form-group">
                    <label>🏦 Mandiri - a.n.</label>
                    <input type="text" id="mandiriAn" value="Sindi Rosmiati">
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label>🏧 BRI - Nomor Rekening</label>
                    <input type="text" id="briRek" value="1234 5678 9012 3456">
                </div>
                <div class="form-group">
                    <label>🏧 BRI - a.n.</label>
                    <input type="text" id="briAn" value="Fikri & Sindi">
                </div>
            </div>

            <hr>

            <!-- Link & Kontak -->
            <div class="row">
                <div class="form-group">
                    <label>🗺️ Link Google Maps</label>
                    <input type="text" id="mapsLink" value="https://maps.app.goo.gl/6fNTUMAbQiqNRJ566">
                </div>
                <div class="form-group">
                    <label>📱 WhatsApp Konfirmasi</label>
                    <input type="text" id="waLink" value="6282249786900">
                </div>
            </div>

            <div class="form-group">
                <label>📺 Link Live Streaming (opsional)</label>
                <input type="text" id="liveLink" placeholder="https://youtube.com/live/...">
            </div>

            <button type="button" class="btn-generate" onclick="generateWedding()">🎉 Generate Undangan 🎉</button>
        </form>

        <div class="result" id="resultArea" style="display:none;">
            <h3>📋 Kode HTML Undangan</h3>
            <textarea id="outputCode" class="result-code" readonly></textarea>
            <button class="copy-btn" onclick="copyToClipboard()">📋 Copy ke Clipboard</button>
            <p class="note">💡 Paste kode di atas ke file index.html di repository GitHub, lalu push.</p>
        </div>
    </div>

    <script>
        function generateWedding() {
            // Ambil nilai dari form
            const namaPria = document.getElementById('namaPria').value;
            const namaWanita = document.getElementById('namaWanita').value;
            const ortuPria = document.getElementById('ortuPria').value;
            const ortuWanita = document.getElementById('ortuWanita').value;
            const tanggal = document.getElementById('tanggal').value;
            const waktu = document.getElementById('waktu').value;
            const lokasi = document.getElementById('lokasi').value;
            const petunjuk = document.getElementById('petunjuk').value;
            const bcaRek = document.getElementById('bcaRek').value;
            const bcaAn = document.getElementById('bcaAn').value;
            const mandiriRek = document.getElementById('mandiriRek').value;
            const mandiriAn = document.getElementById('mandiriAn').value;
            const briRek = document.getElementById('briRek').value;
            const briAn = document.getElementById('briAn').value;
            const mapsLink = document.getElementById('mapsLink').value;
            const waLink = document.getElementById('waLink').value;
            const liveLink = document.getElementById('liveLink').value;

            // HTML Template (sama seperti kode undangan final)
            // Karena panjang, saya akan generate kode lengkap dengan data yang diisi
            
            let htmlCode = `<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
<title>${namaPria} & ${namaWanita} - Pernikahan</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700;800&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ========== CSS SAMA SEPERTI KODE SEBELUMNYA ========== */
/* (saya masukkan CSS lengkap di sini) */
</style>
</head>
<body>
<!-- KONTEN HTML -->
</body>
</html>`;

            // Tampilkan hasil
            document.getElementById('outputCode').value = htmlCode;
            document.getElementById('resultArea').style.display = 'block';
            document.getElementById('outputCode').style.display = 'block';
            
            // Scroll ke hasil
            document.getElementById('resultArea').scrollIntoView({ behavior: 'smooth' });
        }

        function copyToClipboard() {
            const code = document.getElementById('outputCode');
            code.select();
            document.execCommand('copy');
            alert('✅ Kode HTML berhasil disalin! Sekarang paste ke file index.html di repository GitHub.');
        }
    </script>
</body>
</html>
